<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Juego: Reto de Compras y Aprovisionamiento</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #0f172a 0%, #312e81 100%);
            min-height: 100vh;
        }
        .option-btn {
            transition: all 0.2s ease-in-out;
        }
        .option-btn:disabled {
            cursor: not-allowed;
            transform: none !important;
        }
        .correct {
            background-color: #22c55e !important; /* Green 500 */
            color: white !important;
            border-color: #16a34a !important;
        }
        .incorrect {
            background-color: #ef4444 !important; /* Red 500 */
            color: white !important;
            border-color: #dc2626 !important;
        }
        .fade-in {
            animation: fadeIn 0.5s ease-in;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body class="flex items-center justify-center p-4">

    <div class="w-full max-w-3xl bg-white rounded-2xl shadow-2xl overflow-hidden relative">
        <!-- Barra de progreso -->
        <div id="progress-container" class="h-2 w-full bg-gray-200 hidden">
            <div id="progress-bar" class="h-full bg-indigo-600 transition-all duration-300 w-0"></div>
        </div>

        <div class="p-8 sm:p-10">
            <!-- Pantalla de Inicio -->
            <div id="start-screen" class="text-center fade-in">
                <div class="mb-6 flex justify-center">
                    <span class="text-6xl">📦</span>
                </div>
                <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900 mb-4">Reto: Compras y Aprovisionamiento</h1>
                <p class="text-gray-600 text-lg mb-8">Demuestra tus conocimientos sobre el Capítulo 3. ¿Estás listo para tomar las mejores decisiones de negocio?</p>
                <button onclick="startGame()" class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-4 px-10 rounded-xl text-xl shadow-lg hover:shadow-xl transition transform hover:-translate-y-1">
                    ¡Comenzar Juego!
                </button>
            </div>

            <!-- Pantalla de Juego -->
            <div id="game-screen" class="hidden fade-in">
                <div class="flex justify-between items-center mb-6">
                    <span id="question-counter" class="text-indigo-600 font-bold text-lg">Pregunta 1/8</span>
                    <div class="bg-indigo-100 text-indigo-800 font-bold px-4 py-2 rounded-lg">
                        Puntos: <span id="score-display">0</span>
                    </div>
                </div>

                <h2 id="question-text" class="text-xl sm:text-2xl font-semibold text-gray-800 mb-8 min-h-[4rem]">
                    <!-- La pregunta se insertará aquí -->
                </h2>

                <div id="options-grid" class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
                    <!-- Las opciones se insertarán aquí -->
                </div>

                <div id="feedback-container" class="hidden mb-6 p-4 rounded-lg text-center font-semibold text-lg">
                    <!-- El feedback (Correcto/Incorrecto) se insertará aquí -->
                </div>

                <div class="flex justify-end hidden" id="next-btn-container">
                    <button onclick="nextQuestion()" class="bg-gray-800 hover:bg-gray-900 text-white font-bold py-3 px-8 rounded-lg shadow transition transform hover:-translate-y-1">
                        Siguiente Pregunta ➔
                    </button>
                </div>
            </div>

            <!-- Pantalla Final -->
            <div id="end-screen" class="hidden text-center fade-in">
                <div id="end-icon" class="text-6xl mb-4">🏆</div>
                <h2 class="text-3xl font-extrabold text-gray-900 mb-2">¡Juego Terminado!</h2>
                <p class="text-gray-600 text-lg mb-6">Aquí están tus resultados:</p>
                
                <div class="bg-gray-50 border-2 border-dashed border-gray-300 rounded-xl p-8 mb-8">
                    <div class="text-5xl font-black text-indigo-600 mb-2">
                        <span id="final-score">0</span> / 8
                    </div>
                    <p id="final-message" class="text-xl font-semibold text-gray-800 mt-4"></p>
                </div>

                <button onclick="startGame()" class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 px-8 rounded-xl shadow-lg transition transform hover:-translate-y-1">
                    ↻ Volver a jugar
                </button>
            </div>
        </div>
    </div>

    <script>
        const questions = [
            {
                question: "¿Cuál es el punto de partida o el evento que inicia el proceso de gestión de aprovisionamiento en una empresa?",
                options: [
                    "La firma de un contrato con un nuevo proveedor.",
                    "El surgimiento y detección de una necesidad.",
                    "El pago de la factura a los proveedores actuales.",
                    "La revisión de los niveles de inventario sobrante."
                ],
                answer: 1,
                rationale: "Todo proceso nace al identificar y justificar qué producto o servicio requiere la empresa."
            },
            {
                question: "Según los principios básicos, una buena gestión implica adquirir el material correcto, con la calidad correcta, en la cantidad correcta, al precio correcto y...",
                options: [
                    "Con el empaque más atractivo.",
                    "Del proveedor más cercano geográficamente.",
                    "Con la tecnología más costosa del mercado.",
                    "En el momento correcto."
                ],
                answer: 3,
                rationale: "El factor tiempo es crucial para que la cadena de suministro no se detenga."
            },
            {
                question: "¿Qué variables fundamentales se deben evaluar al momento de comparar y seleccionar a los proveedores?",
                options: [
                    "Cualidades, calidades, precios, lead time y financiamiento.",
                    "Únicamente el precio y el prestigio de la marca.",
                    "La cantidad de empleados y la ubicación de sus oficinas.",
                    "El volumen de ventas anuales del proveedor en otros países."
                ],
                answer: 0,
                rationale: "Se requiere un análisis integral que equilibre costo, calidad, tiempo de respuesta y facilidades de pago."
            },
            {
                question: "¿A qué se refiere el término 'lead time' en el proceso de compras?",
                options: [
                    "A la cantidad de días que tiene la empresa para pagar la factura.",
                    "Al tiempo de espera desde que se hace el pedido hasta que se recibe el material.",
                    "Al tiempo de vida útil que tienen los materiales en la bodega.",
                    "A los años de experiencia que tiene el proveedor en el mercado."
                ],
                answer: 1,
                rationale: "Es el tiempo de tránsito físico y velocidad de respuesta del proveedor."
            },
            {
                question: "Dentro de la cadena de suministro, la gestión de compras es considerada como un proceso de naturaleza...",
                options: [
                    "Exclusivamente financiera y contable.",
                    "Únicamente operativa y de trabajo manual.",
                    "Estratégica y operativa.",
                    "Secundaria y de soporte básico opcional."
                ],
                answer: 2,
                rationale: "Involucra tanto la ejecución del día a día como la alineación con los grandes objetivos de rentabilidad."
            },
            {
                question: "¿Quién o quiénes pueden proponer o generar la 'necesidad' que detona una compra en la organización?",
                options: [
                    "Solo el cliente interno (empleados u otros departamentos).",
                    "Solo el cliente externo (consumidores finales del producto).",
                    "Únicamente el área de finanzas o la gerencia general.",
                    "Tanto el cliente interno como el cliente externo."
                ],
                answer: 3,
                rationale: "Un requerimiento puede nacer del propio funcionamiento de la empresa o por nuevas demandas del mercado."
            },
            {
                question: "Una vez que la necesidad de adquirir algo es detectada, ¿cuál es el siguiente paso lógico en el proceso?",
                options: [
                    "Organizar, clasificar y asignar a los posibles proveedores.",
                    "Pagar inmediatamente un anticipo al primer contacto.",
                    "Llamar al cliente para informarle del costo.",
                    "Archivar la solicitud hasta el próximo año fiscal."
                ],
                answer: 0,
                rationale: "Con la necesidad clara, se debe investigar en el mercado quién tiene la capacidad de satisfacerla."
            },
            {
                question: "Si un proveedor ofrece el precio más bajo de todo el mercado, pero su 'lead time' es muy largo, ¿por qué podría NO ser la mejor opción?",
                options: [
                    "Porque los proveedores lentos nunca ofrecen buenas opciones de financiamiento.",
                    "Porque la empresa prefiere siempre gastar más presupuesto para verse prestigiosa.",
                    "Porque podría provocar retrasos, paros en la producción y desabastecimiento.",
                    "Porque un precio bajo es siempre sinónimo de un producto defectuoso."
                ],
                answer: 2,
                rationale: "Un retraso en la entrega puede paralizar la fábrica, costando más que el ahorro inicial."
            }
        ];

        let currentQuestionIndex = 0;
        let score = 0;

        const startScreen = document.getElementById('start-screen');
        const gameScreen = document.getElementById('game-screen');
        const endScreen = document.getElementById('end-screen');
        const questionText = document.getElementById('question-text');
        const optionsGrid = document.getElementById('options-grid');
        const questionCounter = document.getElementById('question-counter');
        const scoreDisplay = document.getElementById('score-display');
        const nextBtnContainer = document.getElementById('next-btn-container');
        const feedbackContainer = document.getElementById('feedback-container');
        const progressBar = document.getElementById('progress-bar');
        const progressContainer = document.getElementById('progress-container');

        function startGame() {
            currentQuestionIndex = 0;
            score = 0;
            scoreDisplay.textContent = score;
            startScreen.classList.add('hidden');
            endScreen.classList.add('hidden');
            gameScreen.classList.remove('hidden');
            progressContainer.classList.remove('hidden');
            updateProgress();
            renderQuestion();
        }

        function renderQuestion() {
            // Reset state
            nextBtnContainer.classList.add('hidden');
            feedbackContainer.classList.add('hidden');
            optionsGrid.innerHTML = '';
            
            const currentQuestion = questions[currentQuestionIndex];
            questionCounter.textContent = `Pregunta ${currentQuestionIndex + 1} de ${questions.length}`;
            questionText.textContent = currentQuestion.question;

            currentQuestion.options.forEach((optionText, index) => {
                const button = document.createElement('button');
                button.textContent = optionText;
                button.className = 'option-btn bg-gray-50 border-2 border-gray-200 hover:border-indigo-400 hover:bg-indigo-50 text-gray-700 font-medium py-4 px-6 rounded-xl text-left w-full shadow-sm';
                button.onclick = () => checkAnswer(index, button);
                optionsGrid.appendChild(button);
            });
        }

        function checkAnswer(selectedIndex, selectedButton) {
            const currentQuestion = questions[currentQuestionIndex];
            const buttons = optionsGrid.querySelectorAll('button');
            
            // Disable all buttons
            buttons.forEach(btn => btn.disabled = true);

            if (selectedIndex === currentQuestion.answer) {
                // Correct answer
                selectedButton.classList.add('correct');
                score++;
                scoreDisplay.textContent = score;
                showFeedback(true, currentQuestion.rationale);
            } else {
                // Incorrect answer
                selectedButton.classList.add('incorrect');
                // Highlight the correct one
                buttons[currentQuestion.answer].classList.add('correct');
                showFeedback(false, currentQuestion.rationale);
            }

            nextBtnContainer.classList.remove('hidden');
        }

        function showFeedback(isCorrect, rationale) {
            feedbackContainer.classList.remove('hidden');
            feedbackContainer.classList.remove('bg-green-100', 'text-green-800', 'bg-red-100', 'text-red-800');
            
            if (isCorrect) {
                feedbackContainer.classList.add('bg-green-100', 'text-green-800');
                feedbackContainer.innerHTML = `<strong>¡Correcto! 🎉</strong><br><span class="text-sm mt-1 block">${rationale}</span>`;
            } else {
                feedbackContainer.classList.add('bg-red-100', 'text-red-800');
                feedbackContainer.innerHTML = `<strong>¡Incorrecto! ❌</strong><br><span class="text-sm mt-1 block">${rationale}</span>`;
            }
        }

        function nextQuestion() {
            currentQuestionIndex++;
            updateProgress();
            
            if (currentQuestionIndex < questions.length) {
                // Re-trigger fade-in animation
                gameScreen.classList.remove('fade-in');
                void gameScreen.offsetWidth; // trigger reflow
                gameScreen.classList.add('fade-in');
                renderQuestion();
            } else {
                showEndScreen();
            }
        }

        function updateProgress() {
            const percentage = ((currentQuestionIndex) / questions.length) * 100;
            progressBar.style.width = `${percentage}%`;
        }

        function showEndScreen() {
            gameScreen.classList.add('hidden');
            progressContainer.classList.add('hidden');
            endScreen.classList.remove('hidden');
            
            document.getElementById('final-score').textContent = score;
            const messageEl = document.getElementById('final-message');
            const iconEl = document.getElementById('end-icon');
            
            if (score === questions.length) {
                messageEl.textContent = "¡Excelente! Eres un maestro de la Cadena de Suministro.";
                iconEl.textContent = "👑";
            } else if (score >= questions.length / 2) {
                messageEl.textContent = "¡Buen trabajo! Tienes bases sólidas, pero puedes mejorar.";
                iconEl.textContent = "👍";
            } else {
                messageEl.textContent = "Hay que repasar un poco más el Capítulo 3. ¡Inténtalo de nuevo!";
                iconEl.textContent = "📚";
            }
        }
    </script>
</body>
</html>